# ==================================
# ClauSync.ai Monorepo Root .gitignore
# ==================================

# --------------------------
# OS Generated Files
# --------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# --------------------------
# Editors & IDEs
# --------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.iml

# --------------------------
# Environment & Secrets
# --------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key
secrets/
.secrets
credentials.json
service-account*.json

# --------------------------
# Node.js
# --------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --------------------------
# Python
# --------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/
.python-version
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# --------------------------
# Build Output
# --------------------------
dist/
out/
.next/
.turbo/
*.tsbuildinfo

# --------------------------
# Logs
# --------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# --------------------------
# Testing
# --------------------------
coverage/
.nyc_output/
*.lcov

# --------------------------
# Misc
# --------------------------
.cache/
.temp/
.tmp/
*.bak
*.backup
