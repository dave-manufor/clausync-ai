# Analysis Worker Environment Variables
# Copy this file to .env and fill in the values

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Pub/Sub
PUBSUB_SUBSCRIPTION_ID=event.change_detected-sub
PUBSUB_TOPIC_NOTIFY=cmd.send_notification

# Cloud Storage
GCS_BUCKET_NAME=legalwatch-snapshots

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/clausync_db
