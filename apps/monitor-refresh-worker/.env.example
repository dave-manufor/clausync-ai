# Monitor Refresh Worker Environment Variables

# Required
DATABASE_URL=postgresql://clausync:localdev@postgres:5432/clausync_db
GCP_PROJECT_ID=clausync-dev
PUBSUB_TOPIC_SCRAPE=cmd.scrape_url

# Optional
PORT=8085
CRON_SECRET=dev-cron-secret
BATCH_SIZE=100
NODE_ENV=development

# For local development with Pub/Sub emulator
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
