# API Service Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=8080
NODE_ENV=development

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id

# Database (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/clausync_db

# Pub/Sub
PUBSUB_TOPIC_SCRAPE=cmd.scrape_url

# GCP Identity Platform (Authentication)
# The audience claim expected in ID tokens. Usually your GCP Project ID or Firebase Project ID.
IDENTITY_PLATFORM_AUDIENCE=your-gcp-project-id

# Super Admin Emails (comma-separated)
# These emails bypass email verification requirement
SUPER_ADMIN_EMAILS=admin@yourcompany.com

# Redis (Rate Limiting)
REDIS_URL=redis://localhost:6379
