// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String            @id @default(uuid()) @db.Uuid
  name               String
  paymentCustomerId  String?           @map("payment_customer_id")  // PayStack/Stripe customer ID
  homeRegion         String            @default("us-central1") @map("home_region")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  
  users              User[]
  invitations        Invitation[]
  webhooks           WebhookEndpoint[]
  subscription       OrganizationSubscription?

  @@map("organizations")
}

model User {
  id                  String                 @id @default(uuid()) @db.Uuid
  organizationId      String?                @map("organization_id") @db.Uuid
  identityProviderUid String                 @unique @map("identity_provider_uid")
  email               String
  name                String?                // Display name
  role                String                 @default("member") // viewer, member, admin, owner
  deletedAt           DateTime?              @map("deleted_at") @db.Timestamptz // Soft delete for GDPR
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  organization           Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions          Subscription[]
  notifications          Notification[]
  contextEmbeddings      UserContextEmbedding[]
  apiKeys                ApiKey[]
  dataExports            DataExport[]
  deletionRequest        DeletionRequest?
  notificationPreference NotificationPreference?
  documents              UserDocument[]
  reports                Report[]
  sessions               Session[]

  @@map("users")
}

// User login sessions for session management
model Session {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  deviceInfo   String?   @map("device_info")    // User-Agent parsed info
  ipAddress    String?   @map("ip_address")
  ssoProvider  String?   @map("sso_provider")   // google.com, microsoft.com, etc.
  lastActiveAt DateTime  @default(now()) @map("last_active_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastActiveAt])
  @@map("sessions")
}

model MonitoredResource {
  id            String             @id @default(uuid()) @db.Uuid
  urlNormalized String             @map("url_normalized")
  selector      String             @default("body")
  currentHash   String?            @map("current_hash")
  lastScrapedAt DateTime?          @map("last_scraped_at") @db.Timestamptz
  nextCheckAt   DateTime?          @map("next_check_at") @db.Timestamptz    // When to check next (scheduler)
  claimedAt     DateTime?          @map("claimed_at") @db.Timestamptz       // Claimed by scheduler (for idempotency)
  deletedAt     DateTime?          @map("deleted_at") @db.Timestamptz // Soft delete
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions Subscription[]
  snapshots     ResourceSnapshot[]
  changeEvents  ChangeEvent[]

  @@unique([urlNormalized, selector])
  @@index([nextCheckAt])  // For efficient scheduler queries
  @@map("monitored_resources")
}

model Subscription {
  id                      String            @id @default(uuid()) @db.Uuid
  userId                  String            @map("user_id") @db.Uuid
  resourceId              String            @map("resource_id") @db.Uuid
  displayName             String?           @map("display_name")
  personalizationEnabled  Boolean           @default(false) @map("personalization_enabled")
  pausedAt                DateTime?         @map("paused_at") @db.Timestamptz // When monitoring was paused
  deletedAt               DateTime?         @map("deleted_at") @db.Timestamptz // Soft delete for GDPR
  deletedBy               String?           @map("deleted_by") @db.Uuid  // Who deleted (audit trail)
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz

  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource                MonitoredResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@map("subscriptions")
}

model ResourceSnapshot {
  id          String            @id @default(uuid()) @db.Uuid
  resourceId  String            @map("resource_id") @db.Uuid
  gcsUri      String            @map("gcs_uri")
  contentHash String            @map("content_hash")
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz // Soft delete
  scrapedAt   DateTime          @default(now()) @map("scraped_at") @db.Timestamptz

  resource    MonitoredResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  oldEvents   ChangeEvent[]     @relation("OldSnapshot")
  newEvents   ChangeEvent[]     @relation("NewSnapshot")

  @@map("resource_snapshots")
}

model ChangeEvent {
  id              String            @id @default(uuid()) @db.Uuid
  resourceId      String            @map("resource_id") @db.Uuid
  oldSnapshotId   String?           @map("old_snapshot_id") @db.Uuid
  newSnapshotId   String?           @map("new_snapshot_id") @db.Uuid
  diffJson        Json?             @map("diff_json")
  globalAiSummary String?           @map("global_ai_summary")
  globalRiskScore Int?              @map("global_risk_score")
  riskKeywords    String[]          @map("risk_keywords")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz

  resource        MonitoredResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  oldSnapshot     ResourceSnapshot? @relation("OldSnapshot", fields: [oldSnapshotId], references: [id])
  newSnapshot     ResourceSnapshot? @relation("NewSnapshot", fields: [newSnapshotId], references: [id])
  notifications   Notification[]

  @@map("change_events")
}

model UserContextEmbedding {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  sourceFilename String?  @map("source_filename")
  contentChunk   String   @map("content_chunk")
  // Note: pgvector type not natively supported by Prisma, use raw SQL for embedding queries
  // embedding      Unsupported("vector(768)")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_context_embeddings")
}

model Notification {
  id                  String       @id @default(uuid()) @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  changeEventId       String?      @map("change_event_id") @db.Uuid
  personalizedSummary String?      @map("personalized_summary")
  riskLevel           String?      @map("risk_level")
  isRead              Boolean      @default(false) @map("is_read")
  sentAt              DateTime?    @map("sent_at") @db.Timestamptz
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  changeEvent         ChangeEvent? @relation(fields: [changeEventId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model AuditLog {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String?   @map("user_id") @db.Uuid
  action        String
  entityType    String    @map("entity_type")
  entityId      String?   @map("entity_id") @db.Uuid
  details       Json?
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  durationMs    Int?      @map("duration_ms")
  resourceAfter Json?     @map("resource_after")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// API Key for programmatic access
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String    // Friendly name for the key
  keyPrefix   String    @map("key_prefix") @db.VarChar(12)  // First chars for identification (clau_live_)
  keyHash     String    @unique @map("key_hash")            // SHA-256 hash of full key
  scopes      String[]  @default([])                        // Granular permissions
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// Organization invitations
model Invitation {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String
  role           String    @default("member")
  token          String    @unique
  invitedBy      String    @map("invited_by") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
  @@map("invitations")
}

// GDPR Data Exports
model DataExport {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  status    String    @default("pending") // pending, processing, ready, expired
  fileUrl   String?   @map("file_url")
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("data_exports")
}

// Account deletion requests (GDPR)
model DeletionRequest {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @map("user_id") @db.Uuid
  status          String    @default("pending") // pending, cancelled, completed
  scheduledAt     DateTime  @map("scheduled_at") @db.Timestamptz // 30 days from now
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deletion_requests")
}

// Webhook endpoints for external integrations
model WebhookEndpoint {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    // Friendly name
  url            String    // Target URL
  secret         String    // HMAC signing secret
  events         String[]  // Events to send: change.detected, risk.high, monitor.created
  enabled        Boolean   @default(true)
  lastDeliveryAt DateTime? @map("last_delivery_at") @db.Timestamptz
  lastStatus     Int?      @map("last_status") // Last HTTP status
  failureCount   Int       @default(0) @map("failure_count")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("webhook_endpoints")
}

// User notification preferences (GDPR: user controls their data processing)
model NotificationPreference {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  emailEnabled    Boolean  @default(true) @map("email_enabled")  // CAN-SPAM compliance
  digestFrequency String   @default("instant") @map("digest_frequency") // instant, daily, weekly
  riskThreshold   Int      @default(5) @map("risk_threshold") // 1-10, only notify above this
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// User uploaded documents for RAG personalization
model UserDocument {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  filename   String
  mimeType   String    @map("mime_type")
  fileSize   Int       @map("file_size") // bytes
  gcsUri     String    @map("gcs_uri")
  status     String    @default("pending") // pending, processing, ready, failed
  chunkCount Int?      @map("chunk_count")
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz // Soft delete for GDPR
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_documents")
}

// Generated analytics reports
model Report {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  type        String    // risk_summary, change_history, compliance
  status      String    @default("pending") // pending, processing, ready, failed
  format      String    @default("pdf") // pdf, csv
  parameters  Json      // period, resourceIds, filters, etc.
  fileUrl     String?   @map("file_url") // GCS signed URL or path
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("reports")
}

// Subscription tier definitions (archiveable)
model SubscriptionTier {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @unique // free, pro, business, enterprise
  displayName     String    @map("display_name")
  priceMonthly    Int       @map("price_monthly")     // cents (0 for free)
  priceYearly     Int       @map("price_yearly")      // cents
  currency        String    @default("USD")
  monitorLimit    Int       @map("monitor_limit")
  teamLimit       Int       @map("team_limit")
  documentLimit   Int       @map("document_limit")
  apiRateLimit    Int       @map("api_rate_limit")    // requests per month
  checkFrequency  String    @default("daily") @map("check_frequency") // weekly, daily, hourly
  historyDays     Int       @map("history_days")
  reportsPerMonth Int?      @map("reports_per_month")
  webhookLimit    Int       @default(0) @map("webhook_limit")
  features        Json?     // Additional feature flags
  isActive        Boolean   @default(true) @map("is_active")  // false = archived
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  subscriptions   OrganizationSubscription[]

  @@map("subscription_tiers")
}

// Organization subscription to a tier
model OrganizationSubscription {
  id                      String    @id @default(uuid()) @db.Uuid
  organizationId          String    @unique @map("organization_id") @db.Uuid
  tierId                  String    @map("tier_id") @db.Uuid
  paymentSubscriptionId   String?   @map("payment_subscription_id")  // PayStack/Stripe subscription ID
  status                  String    @default("trialing")  // trialing, active, past_due, canceled, paused
  currentPeriodStart      DateTime? @map("current_period_start") @db.Timestamptz
  currentPeriodEnd        DateTime? @map("current_period_end") @db.Timestamptz
  trialEndsAt             DateTime? @map("trial_ends_at") @db.Timestamptz
  canceledAt              DateTime? @map("canceled_at") @db.Timestamptz
  cancelAtPeriodEnd       Boolean   @default(false) @map("cancel_at_period_end")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tier                    SubscriptionTier @relation(fields: [tierId], references: [id])

  @@index([tierId])
  @@map("organization_subscriptions")
}

// Usage tracking for billing (API requests, reports, etc.)
model UsageRecord {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  metric          String    // api_requests, reports_generated, ai_queries
  count           Int       @default(0)
  periodStart     DateTime  @map("period_start") @db.Date   // First day of month
  periodEnd       DateTime  @map("period_end") @db.Date     // Last day of month
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([organizationId, metric, periodStart])
  @@index([organizationId, periodStart])
  @@map("usage_records")
}
