# Notification Worker Environment Variables
# Copy this file to .env and fill in the values

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id

# Pub/Sub
PUBSUB_SUBSCRIPTION_ID=cmd.send_notification-sub

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/clausync_db

# Resend (Email Service)
# Acquire from: https://resend.com/api-keys > Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
# This address must be verified in your Resend Dashboard
EMAIL_FROM=alerts@yourdomain.com
