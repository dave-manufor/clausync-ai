# Vectorize Worker Environment Variables
# Copy this file to .env and fill in the values

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Pub/Sub
PUBSUB_SUBSCRIPTION_ID=cmd.vectorize_doc-sub

# Cloud Storage (for user uploads)
GCS_BUCKET_NAME=legalwatch-uploads

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/clausync_db

# Vertex AI Embedding Model
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# Chunking Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
