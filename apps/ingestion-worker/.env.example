# Ingestion Worker Environment Variables
# Copy this file to .env and fill in the values

# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id

# Pub/Sub
PUBSUB_SUBSCRIPTION_ID=cmd.scrape_url-sub
PUBSUB_TOPIC_ID=event.change_detected

# Cloud Storage (WORM Bucket)
GCS_BUCKET_NAME=legalwatch-snapshots

# Redis (Distributed Locking)
REDIS_HOST=localhost
REDIS_PORT=6379

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/clausync_db

# Proxy (Bright Data)
# Acquire from: https://brightdata.com/ Dashboard > Zone > Access Parameters
PROXY_HOST=your-brightdata-host.brightdata.com
PROXY_PORT=22225
PROXY_USER=your-brightdata-username
PROXY_PASS=your-brightdata-password
