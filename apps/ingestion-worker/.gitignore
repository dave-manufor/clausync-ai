# ==================================
# Python Worker .gitignore
# (Ingestion Worker - Playwright Scraper)
# ==================================

# --------------------------
# OS Generated Files
# --------------------------
.DS_Store
Thumbs.db
*.swp
*~

# --------------------------
# Environment & Secrets
# --------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials.json
service-account*.json

# --------------------------
# Python Bytecode
# --------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# --------------------------
# Virtual Environments
# --------------------------
.venv/
venv/
ENV/
env/
.python-version

# --------------------------
# Distribution / Build
# --------------------------
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --------------------------
# Testing
# --------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# --------------------------
# Type Checking / Linting
# --------------------------
.mypy_cache/
.ruff_cache/
.pytype/

# --------------------------
# Logs
# --------------------------
logs/
*.log
pip-log.txt
pip-delete-this-directory.txt

# --------------------------
# IDE
# --------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# --------------------------
# Playwright Specific
# --------------------------
playwright-report/
test-results/
.playwright/

# --------------------------
# Misc
# --------------------------
.cache/
*.bak
