# Data Export Worker Environment Variables
# Copy this file to .env and fill in the values

# GCP Configuration
GCP_PROJECT_ID=clausync-dev

# Database (PostgreSQL)
DATABASE_URL=postgresql://clausync:localdev@postgres:5432/clausync_db

# GCS Bucket for exports
GCS_BUCKET_NAME=clausync-exports

# Pub/Sub topic for notifications
PUBSUB_TOPIC_NOTIFICATION=cmd.send_notification

# Worker Settings
RUN_INTERVAL_SECONDS=30
EXPORT_EXPIRY_DAYS=7

# Storage Emulator (for local dev)
STORAGE_EMULATOR_HOST=http://gcs-emulator:4443
